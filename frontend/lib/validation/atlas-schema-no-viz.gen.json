", "type": "string"}}, "required": ["type", "query"], "title": "SqlParameterSource", "type": "object"}}, "discriminator": {"mapping": {"dashboard": "#/$defs/AtlasDashboardFile", "question": "#/$defs/AtlasQuestionFile"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/$defs/AtlasQuestionFile"}, {"$ref": "#/$defs/AtlasDashboardFile"}]}
