{
  "$defs": {
    "AtlasQuestionFile": {
      "type": "object",
      "required": [
        "name",
        "path",
        "type",
        "content"
      ],
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "question"
        },
        "content": {
          "type": "object",
          "required": [
            "query",
            "vizSettings",
            "connection_name"
          ],
          "properties": {
            "description": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "query": {
              "type": "string",
              "description": "SQL query string, may contain :paramName tokens"
            },
            "vizSettings": {
              "type": "object",
              "description": "vizSettings — see ExecuteQuery.vizSettings for schema"
            },
            "parameters": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "name",
                      "type"
                    ],
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "type": {
                        "type": "string",
                        "enum": [
                          "text",
                          "number",
                          "date"
                        ]
                      },
                      "label": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "source": {
                        "anyOf": [
                          {
                            "anyOf": [
                              {
                                "type": "object",
                                "required": [
                                  "type",
                                  "id",
                                  "column"
                                ],
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "const": "question"
                                  },
                                  "id": {
                                    "type": "integer"
                                  },
                                  "column": {
                                    "type": "string"
                                  }
                                },
                                "title": "QuestionParameterSource"
                              },
                              {
                                "type": "object",
                                "required": [
                                  "type",
                                  "query"
                                ],
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "const": "sql"
                                  },
                                  "query": {
                                    "type": "string"
                                  }
                                },
                                "title": "SqlParameterSource"
                              }
                            ]
                          },
                          {
                            "type": "null"
                          }
                        ]
                      }
                    },
                    "title": "QuestionParameter"
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "parameterValues": {
              "anyOf": [
                {
                  "type": "object",
                  "patternProperties": {
                    "^.*$": {}
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "connection_name": {
              "type": "string",
              "description": "connection name (empty string if none)"
            },
            "references": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "alias"
                    ],
                    "properties": {
                      "id": {
                        "type": "integer"
                      },
                      "alias": {
                        "type": "string"
                      }
                    },
                    "title": "QuestionReference"
                  }
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "title": "QuestionContent"
        },
        "references": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "title": "AtlasQuestionFile"
    },
    "AtlasDashboardFile": {
      "type": "object",
      "required": [
        "name",
        "path",
        "type",
        "content"
      ],
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "dashboard"
        },
        "content": {
          "type": "object",
          "required": [
            "assets"
          ],
          "properties": {
            "description": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "assets": {
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "object",
                    "required": [
                      "type",
                      "id"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "question"
                      },
                      "id": {
                        "type": "integer"
                      }
                    },
                    "title": "FileReference"
                  },
                  {
                    "type": "object",
                    "required": [
                      "type"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": [
                          "text",
                          "image",
                          "divider"
                        ]
                      },
                      "id": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "content": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      }
                    },
                    "title": "InlineAsset"
                  }
                ]
              },
              "description": "ordered list of questions in the dashboard"
            },
            "layout": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "columns": {
                      "type": "integer"
                    },
                    "items": {
                      "anyOf": [
                        {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "required": [
                              "id",
                              "x",
                              "y",
                              "w",
                              "h"
                            ],
                            "properties": {
                              "id": {
                                "anyOf": [
                                  {
                                    "type": "integer"
                                  },
                                  {
                                    "type": "string"
                                  }
                                ]
                              },
                              "x": {
                                "type": "integer"
                              },
                              "y": {
                                "type": "integer"
                              },
                              "w": {
                                "type": "integer",
                                "minimum": 2,
                                "description": "width in grid units (min 2)"
                              },
                              "h": {
                                "type": "integer",
                                "minimum": 1,
                                "description": "height in grid units (min 1)"
                              }
                            },
                            "title": "DashboardLayoutItem"
                          }
                        },
                        {
                          "type": "null"
                        }
                      ]
                    }
                  },
                  "title": "DashboardLayout"
                },
                {
                  "type": "null"
                }
              ]
            },
            "parameterValues": {
              "anyOf": [
                {
                  "type": "object",
                  "patternProperties": {
                    "^.*$": {}
                  }
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "title": "DashboardContent"
        },
        "references": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "title": "AtlasDashboardFile"
    }
  },
  "discriminator": {
    "propertyName": "type"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/AtlasQuestionFile"
    },
    {
      "$ref": "#/$defs/AtlasDashboardFile"
    }
  ]
}
