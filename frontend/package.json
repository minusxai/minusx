{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=3072' next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --cache",
    "validate": "concurrently -g --names tsc,eslint \"tsc --noEmit\" \"eslint --cache --quiet\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:main": "vitest run --project=node",
    "test:orchestrator": "vitest run --project=orchestrator",
    "test:ui": "vitest run --project=ui",
    "update-workspace-template": "tsx --conditions react-server scripts/update-workspace-template.ts",
    "generate-types": "(cd ../backend && uv run python scripts/export_schema.py) | tee lib/validation/atlas-schema.gen.json | node_modules/.bin/json2ts --unreachableDefinitions --additionalProperties=false > lib/types.gen.ts",
    "postinstall": "node scripts/copy-duckdb-wasm.mjs",
    "benchmark:dab": "node --env-file=.env --max-old-space-size=8192 node_modules/.bin/tsx --conditions react-server benchmarks/dataanalystbench.ts"
  },
