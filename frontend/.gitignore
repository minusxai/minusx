# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# chart preview output (generated by scripts/render-chart-previews.ts)
/.chart-previews
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.localprod

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# DuckDB WASM files (copied from node_modules by postinstall)
/public/duckdb/

.eslintcache
.jest-cache/

# benchmark data (sibling files of agents/analyst/__tests__/benchmark_runner.test.ts)
/agents/analyst/__tests__/input.jsonl
/agents/analyst/__tests__/output.jsonl

/benchmarks/*.md
# Sentry Config File
.env.sentry-build-plugin

# Playwright E2E (Tests/QA/Evals Arch V2)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/test/e2e/.auth/
/data/pglite-e2e/
/.next-e2e/
/.next-qa/
/data/pglite-qa/
/test/qa/.auth/

# Generated by npm run prompt-visualizer
prompt-visualizer.html

# Precompiled setup-cli bundle (built into the image by `npm run build:setup-cli`).
# Anchored: an unanchored `setup-cli/` would also swallow scripts/setup-cli/ SOURCE.
/setup-cli/
.setup-cli-bundle-test-*/
