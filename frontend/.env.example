# Copy this file to .env and fill in the values

# Required Secrets
NEXTAUTH_SECRET=

# LLM provider — the in-process agent orchestrator reads the provider key at call
# time. Set ANTHROPIC_API_KEY (default provider) for local development, or point
# at the mx-llm-provider proxy via MX_API_BASE_URL + MX_API_KEY.
ANTHROPIC_API_KEY=
# MX_API_BASE_URL=
# MX_API_KEY=

# Optional (defaults are usually fine for local development)
# AUTH_URL=http://localhost:3000

# Postgres (required for docker-compose.prod.yml; leave unset to use embedded PGLite)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
