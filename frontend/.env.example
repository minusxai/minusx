# Copy this file to .env and fill in the values

# Required Secrets
NEXTAUTH_SECRET=

# Optional (defaults are usually fine for local development)
# BASE_DUCKDB_DATA_PATH=..
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8001
# AUTH_URL=http://localhost:3000
# ADMIN_PWD=

# MX Proxy configuration (optional)
# Set MX_API_BASE_URL to enable fetching LLM request/response blobs in the debug panel.
# The proxy must implement GET /calls/{callId} and GET /calls/{callId}?mode=all
# MX_API_BASE_URL=http://localhost:4001
# MX_API_KEY=

# Default email webhook (optional)
# JSON-encoded MessagingWebhook used app-wide when no company email_alert webhook is configured.
# Shows in Delivery Picker and handles alert/report/error email delivery for all companies.
# Example using Resend:
# DEFAULT_EMAIL_WEBHOOK='{"type":"email_alert","url":"https://api.resend.com/emails","method":"POST","headers":{"Authorization":"Bearer re_xxx"},"body":{"from":"MinusX <noreply@yourdomain.com>","to":["{{EMAIL_TO}}"],"subject":"{{EMAIL_SUBJECT}}","html":"{{EMAIL_BODY}}"}}'