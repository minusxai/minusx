# Copy this file to .env and fill in the values

# Required Secrets
NEXTAUTH_SECRET=

# LLM provider — the in-process agent orchestrator reads the provider key at call
# time. Set ANTHROPIC_API_KEY (default provider) for local development.
ANTHROPIC_API_KEY=

# App-event webhook fan-out. JSON map of { "<event-type regex>": "<webhook url>" }.
# Each published app-event whose type matches a rule is POSTed to that webhook.
# Slack URLs (hooks.slack.com) receive a formatted message; any other URL receives
# the raw event JSON (e.g. a central ingest). Every event is also stored locally in
# the app_events table regardless. Example:
#   EVENTS_FORWARD_RULES={"^error$":"https://hooks.slack.com/services/XXX","^share:lead$":"https://hooks.slack.com/services/YYY"}
# EVENTS_FORWARD_RULES=

# Optional (defaults are usually fine for local development)
# AUTH_URL=http://localhost:3000

# Postgres (required for docker-compose.prod.yml; leave unset to use embedded PGLite)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
