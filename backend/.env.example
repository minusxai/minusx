# Copy this file to .env and fill in the values

# Required keys to use fully self-hosted
ANTHROPIC_API_KEY=

# Object store (S3-compatible) — required for CSV uploads, Google Sheets, and chart images.
# Must match the OBJECT_STORE_* values in frontend/.env (shared bucket).
# OBJECT_STORE_BUCKET=
# OBJECT_STORE_REGION=us-east-1
# OBJECT_STORE_ACCESS_KEY_ID=
# OBJECT_STORE_SECRET_ACCESS_KEY=
# OBJECT_STORE_ENDPOINT=        # Custom endpoint for MinIO/R2 (leave blank for AWS S3)

# Optional (defaults are usually fine for local development)
# NEXTJS_URL=http://localhost:3000
# BASE_DUCKDB_DATA_PATH=.

# Number of Gunicorn workers for production (default: 4)
# Recommended: (2 x CPU cores) + 1
# Examples:
#   - 1 CPU: WORKERS=3
#   - 2 CPU: WORKERS=5
#   - 4 CPU: WORKERS=9
# WORKERS=4